generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma" // uncomment if needed for strict output
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Admin & Settings
// -----------------------------------------------------------------------------

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed via bcrypt/argon2
  role      String   @default("ADMIN") // Role enum mapped to String for SQLite
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Catalog Management
// -----------------------------------------------------------------------------

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String           @id @default(uuid())
  sku            String           @unique
  name           String
  slug           String           @unique
  description    String
  price          Float
  compareAtPrice Float?
  stockQuantity  Int              @default(0)
  isPublished    Boolean          @default(true)
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([slug])
}

model ProductImage {
  id         String   @id @default(uuid())
  url        String
  altText    String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Customer Management (Guest Aggregate)
// -----------------------------------------------------------------------------

model Customer {
  id            String    @id @default(uuid())
  phone         String    @unique // Primary identifier for guests
  firstName     String
  lastName      String
  email         String?
  totalOrders   Int       @default(0)
  lifetimeSpend Float     @default(0.00)
  orders        Order[]
  addresses     Address[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("India")
  isDefault  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Order & Fulfillment Management
// -----------------------------------------------------------------------------

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique // e.g. SH-8492
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  status          String      @default("PENDING_PAYMENT") // OrderStatus mapped to String
  subtotal        Float
  tax             Float
  shippingCost    Float
  totalAmount     Float
  
  // Snapshotted shipping info for historical accuracy
  shippingName    String
  shippingPhone   String
  shippingAddress String
  
  // Razorpay Integration
  razorpayOrderId String?     @unique
  paymentId       String?
  paymentStatus   String      @default("PENDING") // PaymentStatus mapped to String

  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  // Snapshotted details to prevent historical alteration
  quantity  Int
  price     Float
  name      String  // Product name at the time of purchase
}

// -----------------------------------------------------------------------------
// Audit & Operations
// -----------------------------------------------------------------------------

model StockMovement {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int      // Negative for outflow, Positive for inflow
  reason      String   // e.g. "Sale (SH-8492)", "Manual Adjustment", "Restock"
  adminUserId String?  // Reference AdminUser if done manually
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  name      String
  location  String?
  rating    Int      @default(5)
  text      String
  product   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
